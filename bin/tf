#!/usr/bin/env bash

set -euo pipefail

usage() {
  cat <<'EOF'
Usage:
  ./infra/bin/tf shared-delivery <terraform-subcommand> [args...]
  ./infra/bin/tf <env> <stack> <terraform-subcommand> [args...]

Stacks:
  core
  bootstrap
  gitops
  shared-delivery

Examples:
  ./infra/bin/tf shared-delivery init
  ./infra/bin/tf shared-delivery plan
  ./infra/bin/tf dev core init
  ./infra/bin/tf dev core plan
  ./infra/bin/tf prod gitops apply
EOF
}

if [[ $# -lt 2 ]]; then
  usage
  exit 1
fi

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"

if [[ "$1" == "shared-delivery" ]]; then
  env="shared"
  stack="shared-delivery"
  shift
else
  if [[ $# -lt 3 ]]; then
    usage
    exit 1
  fi
  env="$1"
  stack="$2"
  shift 2
fi

terraform_subcommand="$1"
shift

stack_dir="${repo_root}/infra/stacks/${stack}"
if [[ ! -d "${stack_dir}" ]]; then
  echo "Unknown stack: ${stack}" >&2
  exit 1
fi

if [[ "${stack}" == "shared-delivery" ]]; then
  backend_file="${repo_root}/infra/envs/shared/delivery.backend.hcl"
  var_file="${repo_root}/infra/envs/shared/delivery.tfvars"
else
  backend_file="${repo_root}/infra/envs/${env}/${stack}.backend.hcl"
  var_file="${repo_root}/infra/envs/${env}/${stack}.tfvars"
fi

cmd=(terraform "-chdir=${stack_dir}" "${terraform_subcommand}")

case "${terraform_subcommand}" in
  init)
    if [[ -f "${backend_file}" ]]; then
      cmd+=("-backend-config=${backend_file}")
    fi
    ;;
  plan|apply|destroy)
    if [[ -f "${var_file}" ]]; then
      cmd+=("-var-file=${var_file}")
    fi
    ;;
esac

cmd+=("$@")
exec "${cmd[@]}"
